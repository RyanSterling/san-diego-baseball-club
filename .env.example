# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity Write Access (for AI stats entry)
# Create at: sanity.io/manage > Your Project > API > Tokens > Add Token (Editor role)
SANITY_API_TOKEN=your-sanity-write-token

# Email (Resend)
RESEND_API_KEY=re_your-api-key
CONTACT_EMAIL=contact@example.com

# Team Fund Auth
TEAM_FUND_PASSWORD=ilovethedodgers
AUTH_SECRET=generate-a-random-32-character-string-here

# AI Stats Entry (Claude Vision)
# Get your API key at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key
